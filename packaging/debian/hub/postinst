#!/bin/sh
set -e

case "$1" in
    configure)
        if ! getent passwd can-hub >/dev/null 2>&1; then
            adduser --system --group --no-create-home \
                    --home /var/lib/can-hub --gecos "can-hub service" can-hub
        fi
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload >/dev/null 2>&1 || true
            systemctl enable can-hub.service >/dev/null 2>&1 || true
            systemctl start can-hub.service >/dev/null 2>&1 || true
        fi
        ;;
esac

exit 0
